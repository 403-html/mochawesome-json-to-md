{
  "env": {
    "es6": true,
    "browser": false
  },
  "ignorePatterns": [
    "node_modules/"
  ],
  "extends": [
    "airbnb-typescript/base",
    "prettier",
    "node"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 6,
    "sourceType": "module",
    "project": "./tsconfig.json"
  },
  "plugins": [
    "@typescript-eslint",
    "prettier"
  ],
  "rules": {
    "no-process-exit": "off"
  }
}